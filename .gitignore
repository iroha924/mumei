# =============================================================================
# Machine-local state — CLAUDE.md / .claude/ (rules, skills, agents) and
# docs/ dev records are tracked team assets; only per-developer runtime
# state and personal overrides below stay out of git.
# =============================================================================

# Personal per-project Claude Code instructions (official gitignore target)
/CLAUDE.local.md

# Per-developer Claude Code runtime state (never shared)
/.claude/settings.local.json
/.claude/agent-memory/
/.claude/agent-memory-local/
/.claude/worktrees/
/.claude/tdd-guard/

# Maintainer-local design-decision log (deliberately not published)
/docs/mumei-decisions.md

# mumei dogfooding state (this repo drives its own development with mumei)
/.mumei/

# iroha-for-notion session mirror (maintainer-local notes)
/.iroha/

# Taskfile (go-task) local checksum cache; regenerated per dev environment.
.task/

# =============================================================================
# OS / Editor
# =============================================================================

.DS_Store
Thumbs.db
desktop.ini

*.swp
*.swo
*~
.idea/
.vscode/
.zed/

# =============================================================================
# ログ・一時ファイル
# =============================================================================

*.log
*.tmp
/tmp/
/tmp.*
*.bak
*.orig

# =============================================================================
# 秘密情報
# =============================================================================

.env
.env.*
!.env.example

# 鍵・証明書・パスワードストア
*.pem
*.key
id_rsa*
.aws/credentials
.ssh/
*.kdbx

# =============================================================================
# テスト・カバレッジ (将来 bats を入れたとき)
# =============================================================================

/coverage/
*.bats.tmp

# =============================================================================
# Node / Python (テストやスクリプトで使う可能性に備える)
# =============================================================================

node_modules/
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# lychee link checker cache (生成物)
/.lycheecache

# =============================================================================
# ビルド成果物 (現状 mumei は build しないが、将来用)
# =============================================================================

/dist/
/build/
.tmp/
