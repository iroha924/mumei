{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mumei.dev/schemas/feature-detail.schema.json#v0.1.0",
  "title": "mumei feature detail payload",
  "description": "GET /api/feature/:slug/detail result built by dashboard/server/detail.ts from requirements.md + tasks.md (via execFile bash hooks/_lib/tasks.sh) + reviews/*.json + cost-log.jsonl. When planVehicle=true, requirements.md is absent so acs is []. Producer: dashboard backend. Consumer: DetailPanel.tsx.",
  "type": "object",
  "required": [
    "slug",
    "planVehicle",
    "timeline",
    "acs",
    "waveplan",
    "reviews",
    "costPerIter"
  ],
  "additionalProperties": false,
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "planVehicle": {
      "type": "boolean",
      "description": "True when feature lives under .mumei/plans/<slug>/ (no requirements.md). Frontend renders 'no requirements (plan vehicle)' placeholder for the ACs tab."
    },
    "archived": {
      "type": "boolean",
      "description": "True when the feature was found under .mumei/archive/<YYYY-MM>/<slug>/ instead of active specs/plans. Frontend may surface an 'archived' badge to signal that further realtime updates will not arrive (REQ-18.15)."
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ts", "event"],
        "properties": {
          "ts": { "type": "string", "format": "date-time" },
          "event": {
            "type": "string",
            "description": "Short label, e.g. 'created', 'phase: plan -> implement', 'wave 2 commit', 'review iter 1 PASS'."
          },
          "ref": { "type": ["string", "null"], "description": "git rev / review JSON path / null." }
        }
      }
    },
    "acs": {
      "type": "array",
      "description": "Empty array when planVehicle=true.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "body", "confirmed"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^REQ-[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
          },
          "body": { "type": "string" },
          "confirmed": {
            "type": "boolean",
            "description": "True for [CONFIRMED] ACs, false for [ASSUMPTION] / [NEEDS CLARIFICATION]."
          },
          "examples": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "waveplan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["wave", "goal", "verify", "tasks"],
        "properties": {
          "wave": { "type": "integer", "minimum": 1 },
          "goal": { "type": "string" },
          "verify": { "type": "string" },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "description", "done", "files", "depends", "reqs"],
              "properties": {
                "id": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
                "description": { "type": "string" },
                "done": { "type": "boolean" },
                "files": { "type": "array", "items": { "type": "string" } },
                "depends": { "type": "array", "items": { "type": "string" } },
                "reqs": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ts", "verdict", "iteration"],
        "properties": {
          "ts": { "type": "string", "format": "date-time" },
          "verdict": {
            "type": "string",
            "enum": ["PASS", "NEEDS_IMPROVEMENT", "MAJOR_ISSUES"]
          },
          "iteration": { "type": "integer", "minimum": 1, "maximum": 3 },
          "wave": {
            "oneOf": [
              { "type": "integer", "minimum": 1 },
              { "type": "string", "const": "all" }
            ]
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["severity", "message"],
              "properties": {
                "id": { "type": "string" },
                "severity": {
                  "type": "string",
                  "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
                },
                "category": { "type": "string" },
                "message": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "costPerIter": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["iter", "tokens", "cacheHit"],
        "properties": {
          "iter": { "type": "integer", "minimum": 1, "maximum": 3 },
          "tokens": { "type": "integer", "minimum": 0 },
          "cacheHit": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
