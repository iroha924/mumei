{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mumei.dev/schemas/activity-event.schema.json#v0.1.0",
  "title": "mumei activity event",
  "description": "Discriminated union of activity entries returned by GET /api/activity?limit=50 and prepended into ActivityFeed via SSE 'activity.added'. Producer: dashboard/server/activity.ts (merging git log + reviews/*.json + state.json mtime + .hook-stats.jsonl, active + archive). Consumer: dashboard/src/components/ActivityFeed.tsx.",
  "type": "object",
  "required": ["ts", "kind"],
  "properties": {
    "ts": { "type": "string", "format": "date-time" },
    "kind": {
      "type": "string",
      "enum": ["commit", "review", "phase", "hook", "subagent", "task_progress", "archive"]
    }
  },
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ts", "kind", "ref", "message"],
      "properties": {
        "ts": { "type": "string", "format": "date-time" },
        "kind": { "const": "commit" },
        "slug": { "type": ["string", "null"] },
        "ref": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$",
          "description": "git short or full SHA."
        },
        "message": { "type": "string", "description": "First line of commit message." }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ts", "kind", "slug", "verdict", "iter"],
      "properties": {
        "ts": { "type": "string", "format": "date-time" },
        "kind": { "const": "review" },
        "slug": { "type": "string" },
        "verdict": {
          "type": "string",
          "enum": ["PASS", "NEEDS_IMPROVEMENT", "MAJOR_ISSUES"]
        },
        "iter": { "type": "integer", "minimum": 1, "maximum": 3 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ts", "kind", "slug", "from", "to"],
      "properties": {
        "ts": { "type": "string", "format": "date-time" },
        "kind": { "const": "phase" },
        "slug": { "type": "string" },
        "from": {
          "type": ["string", "null"],
          "enum": ["plan", "implement", "review", "done", null],
          "description": "Previous phase. null when transition history is unavailable (no audit-log entry); UI renders as '→ <to>' in that case."
        },
        "to": { "type": "string", "enum": ["plan", "implement", "review", "done"] }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ts", "kind", "hook_id", "decision"],
      "properties": {
        "ts": { "type": "string", "format": "date-time" },
        "kind": { "const": "hook" },
        "hook_id": { "type": "string", "description": "Hook rule short id emitted by hooks/_lib/hook-stats.sh:mumei_hook_stats_record." },
        "decision": {
          "type": "string",
          "enum": ["allow", "deny", "warn", "block", "noop"]
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ts", "kind", "slug", "agent", "phase", "tokens_total"],
      "properties": {
        "ts": { "type": "string", "format": "date-time" },
        "kind": { "const": "subagent" },
        "slug": { "type": "string", "description": "Owning feature key (REQ-N-slug for spec, bare slug for plan)." },
        "agent": { "type": "string", "description": "Subagent name (e.g. spec-compliance-reviewer)." },
        "phase": { "type": "string", "enum": ["before", "after"], "description": "Cost-log phase marker; before / after for delta computation." },
        "tokens_total": { "type": "integer", "minimum": 0, "description": "input_tokens + output_tokens at this entry." }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ts", "kind", "slug", "vehicle", "task_id"],
      "properties": {
        "ts": { "type": "string", "format": "date-time" },
        "kind": { "const": "task_progress" },
        "slug": { "type": "string" },
        "vehicle": { "type": "string", "enum": ["spec", "plan"] },
        "wave": { "type": ["integer", "null"], "minimum": 1, "description": "Wave number for spec vehicle; null for plan vehicle." },
        "task_id": { "type": "string", "description": "Spec: <wave>.<task> like '1.2'. Plan: post-increment task counter as a string." }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["ts", "kind", "slug", "to"],
      "properties": {
        "ts": { "type": "string", "format": "date-time" },
        "kind": { "const": "archive" },
        "slug": { "type": "string" },
        "to": { "type": "string", "description": "Archive destination path (.mumei/archive/<YYYY-MM>/<slug>)." }
      }
    }
  ]
}
