# =============================================================================
# 開発者専用 — mumei plugin の配布物には含めない。
# CLAUDE.md / .claude/ / docs/ はチーム共有もしない (個人開発スタンス)。
# =============================================================================

# 開発者向け CLAUDE.md (配布物の README.md は別、これは追跡する)
/CLAUDE.md

# 開発者環境の Claude Code 設定 (rules / skills / agents / settings)
/.claude/

# リサーチ・決定ログ (dev 専用、ただし配布対象の英語ドキュメントは個別に許可)
/docs/*
!/docs/document-corruption.md
!/docs/threat-model.md
!/docs/security-policy.md
!/docs/opus-4-7-playbook.md
!/docs/getting-started.md
!/docs/getting-started.ja.md
!/docs/review-adoption.md

# mumei plugin を mumei 自身で利用する場合の状態 (dogfood 想定)
/.mumei/

# self-evaluate skill の dev 採点記録 (個人開発スタンス、配布物外)
/skills/self-evaluate/results/

# Taskfile (go-task) ローカル checksum cache。sources/generates の up-to-date
# 判定に使う隠しディレクトリ。dev 環境ごとに再生成されるため共有不要。
.task/

# =============================================================================
# OS / Editor
# =============================================================================

.DS_Store
Thumbs.db
desktop.ini

*.swp
*.swo
*~
.idea/
.vscode/
.zed/

# =============================================================================
# ログ・一時ファイル
# =============================================================================

*.log
*.tmp
/tmp/
/tmp.*
*.bak
*.orig

# =============================================================================
# 秘密情報
# =============================================================================

.env
.env.*
!.env.example

# 鍵・証明書・パスワードストア
*.pem
*.key
id_rsa*
.aws/credentials
.ssh/
*.kdbx

# =============================================================================
# テスト・カバレッジ (将来 bats を入れたとき)
# =============================================================================

/coverage/
*.bats.tmp

# =============================================================================
# Node / Python (テストやスクリプトで使う可能性に備える)
# =============================================================================

node_modules/
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# lychee link checker cache (生成物)
/.lycheecache

# =============================================================================
# ビルド成果物 (現状 mumei は build しないが、将来用)
# =============================================================================

/dist/
/build/
.tmp/
