{
  "name": "mumei-dashboard",
  "version": "0.2.4",
  "description": "Local dev dashboard for mumei: realtime visualisation of feature phases, Wave progress, review verdicts, token cost, and hook firing trends. Reads .mumei/ directly, no external service.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hir4ta/mumei.git",
    "directory": "dashboard"
  },
  "homepage": "https://github.com/hir4ta/mumei/tree/main/dashboard#readme",
  "bugs": "https://github.com/hir4ta/mumei/issues",
  "bin": {
    "mumei-dashboard": "./bin/mumei-dashboard.mjs"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "bin/",
    "dist/",
    "schemas/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently --kill-others --names \"server,vite\" --prefix-colors \"magenta,cyan\" \"npm:dev:server\" \"npm:dev:vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:vite": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc -b && vite build",
    "build:server": "tsup server/index.ts --format esm --target node20 --out-dir dist/server --no-splitting --clean",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "generate-types": "tsx scripts/generate-types.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/static": "^9.1.3",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@sinclair/typebox": "^0.34.13",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.62.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "fastify": "^5.8.0",
    "jsdom": "^25.0.1",
    "json-schema-to-typescript": "^15.0.3",
    "lucide-react": "^0.469.0",
    "msw": "^2.7.0",
    "pino-pretty": "^13.0.0",
    "pngjs": "^7.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
