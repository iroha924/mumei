{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mumei.dev/schemas/state.schema.json",
  "title": "mumei feature state",
  "type": "object",
  "required": [
    "id",
    "slug",
    "phase",
    "current_wave",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^REQ-[0-9]+$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
    },
    "phase": {
      "type": "string",
      "enum": ["plan", "implement", "review", "done"]
    },
    "current_wave": {
      "type": "integer",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
