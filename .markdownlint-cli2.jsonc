// markdownlint-cli2 config
// Reference: https://github.com/DavidAnson/markdownlint/blob/main/doc/Rules.md
{
  "config": {
    "default": true,

    // mumei の README / agents / skills は意図的に長い行を持つ (URL、コードブロック内の長い文)。
    // line-length 厳格化は実用性を損なう。
    "MD013": false,

    // mumei は agent body に <!-- 日本語 --> HTML コメントを意図的に使う (CLAUDE.md 規約)。
    "MD033": false,

    // 同一 heading は意図的にあり得る (例: 複数 reviewer agent の "Output (strict JSON)" セクション)。
    "MD024": false,

    // top-level h1 が無いファイル (issue templates 等) があり得る。
    "MD041": false,

    // mumei の agent body は意図的に `# Role` / `# Inputs` / `# Method` の複数 h1 構造を使う
    // (CLAUDE.md plugin-artifact-conventions 規約)。MD025 は無効化。
    "MD025": false,

    // ordered list の番号は 1. 1. 1. ... ではなく 1. 2. 3. を採用する (auto-renumbering 派ではない)。
    "MD029": { "style": "ordered" },

    // bare-URL は mumei docs 内で技術 URL として頻出。
    "MD034": false,

    // emphasis is used as headings: `*Note*` のようなパターンを Code of Conduct (Contributor Covenant 2.1) が含む。
    "MD036": false,

    // multiple spaces inside emphasis 等の些末ルールは無効化
    "MD037": false,
    "MD038": false,
    "MD039": false
  },
  "globs": [
    "**/*.md"
  ],
  "ignores": [
    "**/node_modules/**",
    "**/dist/**",
    ".mumei/**",
    ".claude/**",
    "docs/**",
    "examples/**",
    "CODE_OF_CONDUCT.md"
  ]
}
