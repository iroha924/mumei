# mumei-dashboard runtime environment.
# Copy to `.env.local` (gitignored) for personal overrides.
# Vite reads only VITE_-prefixed vars on the client side; everything
# else is server-only.

# Fastify backend listen port (also referenced in vite.config.ts proxy).
MUMEI_DASHBOARD_PORT=3001

# pino logger level (trace | debug | info | warn | error | fatal).
# Use 'debug' locally to inspect SSE / chokidar event flow.
MUMEI_DASHBOARD_LOG_LEVEL=info

# Comma-separated origin allowlist for the @fastify/cors plugin.
# Defaults to http://localhost:5173 (Vite dev). Add others for embedding.
MUMEI_DASHBOARD_CORS_ORIGINS=http://localhost:5173
